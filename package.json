{
  "name": "notrus-relay",
  "version": "0.2.0-alpha.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build:android-app": "zsh scripts/build-android-app.sh",
    "build:mac-app": "zsh scripts/build-mac-app.sh",
    "build:protocol-core": "zsh scripts/build-protocol-core.sh",
    "generate:crypto-vectors": "node scripts/generate-crypto-vectors.mjs",
    "generate:sbom": "node scripts/generate-sbom.mjs",
    "notarize:mac-app": "zsh scripts/notarize-mac-app.sh",
    "package:android-app": "zsh scripts/package-android-app.sh",
    "package:mac-app": "zsh scripts/package-mac-app.sh",
    "package:clients": "npm run package:mac-app && npm run package:android-app",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "start": "node server.js",
    "start:attestation": "node attestation.js",
    "start:mac-app": "zsh scripts/start-mac-app.sh",
    "start:witness": "node witness.js",
    "test:attestation-service": "node scripts/test-attestation-service.mjs",
    "test:attestation-enforcement": "node scripts/test-attestation-enforcement.mjs",
    "test:mac-app": "zsh scripts/test-mac-app.sh",
    "test:content-boundary": "node scripts/test-content-boundary.mjs",
    "test:client-surfaces": "node scripts/test-client-surfaces.mjs",
    "test:abuse-controls": "node scripts/test-abuse-controls.mjs",
    "test:metadata-boundary": "node scripts/test-metadata-boundary.mjs",
    "test:privacy-routing": "node scripts/test-privacy-routing.mjs",
    "test:retention-pruning": "node scripts/test-retention-pruning.mjs",
    "test:device-membership": "node scripts/test-device-membership.mjs",
    "test:adversarial-inputs": "node scripts/test-adversarial-inputs.mjs",
    "test:mac-release": "node scripts/verify-mac-release.mjs",
    "test:standards-e2e": "node scripts/test-standards-e2e.mjs",
    "test:protocol-core": "cargo test --manifest-path native/protocol-core/Cargo.toml",
    "test:security-suite": "npm run scan:secrets && npm run test:client-surfaces && npm run test:metadata-boundary && npm run test:content-boundary && npm run test:privacy-routing && npm run test:retention-pruning && npm run test:adversarial-inputs && npm run test:abuse-controls && npm run test:device-membership"
  }
