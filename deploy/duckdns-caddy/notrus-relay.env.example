# Public hostname served by Caddy, for example:
# NOTRUS_PUBLIC_HOST=notrus-relay.duckdns.org
NOTRUS_PUBLIC_HOST=

# Bind the Node relay only to localhost. Caddy is the public HTTPS entrypoint.
HOST=127.0.0.1
PORT=3000

# Persistent relay state. Do not store these paths inside the git repo.
NOTRUS_DATA_DIR=/var/lib/notrus/data
NOTRUS_SECRET_DIR=/var/lib/notrus/secrets

# Production-compatible protocol policy.
NOTRUS_PROTOCOL_POLICY=require-standards
NOTRUS_ENABLE_DEVELOPMENT_COMPAT_ROUTES=false
NOTRUS_ENABLE_LEGACY_API=false

# Safe only when the relay is bound to localhost and Caddy is the trusted local proxy.
TRUST_PROXY=true

# Admin API is opt-in. If enabled, set a long random token.
NOTRUS_ENABLE_ADMIN_API=false
NOTRUS_ADMIN_API_TOKEN=

# Generate stable random values for production. If omitted, runtime-generated values change on restart.
RATE_LIMIT_HMAC_KEY=
POW_HMAC_KEY=

# Optional retention overrides.
# MESSAGE_RETENTION_MS=1209600000
# ATTACHMENT_RETENTION_MS=1209600000
# REPORT_RETENTION_MS=604800000
# DEVICE_EVENT_RETENTION_MS=2592000000
